/* ===============================================================
   Bronze Layer – Data Quality Validation Script
   Purpose:
   - Validate data before loading into Silver Layer.
   - Detect duplicates, nulls, invalid dates, negative values,
     domain inconsistencies, and business rule violations.
   - Expectation: All queries should return NO RESULTS.
   =============================================================== */

PRINT '===========================================';
PRINT 'Bronze Layer Data Quality Checks Started';
PRINT '===========================================';

/* ===============================================================
   1️⃣ crm_cust_info
   =============================================================== */

-- Check for Null or Duplicate Primary Key
SELECT cst_id, COUNT(*) AS duplicate_count
FROM bronze.crm_cust_info
GROUP BY cst_id
HAVING COUNT(*) > 1 OR cst_id IS NULL;

-- Check for unwanted spaces
SELECT *
FROM bronze.crm_cust_info
WHERE cst_firstname != TRIM(cst_firstname)
   OR cst_lastname  != TRIM(cst_lastname);

-- Check Gender Domain
SELECT DISTINCT cst_gndr
FROM bronze.crm_cust_info;

-- Check Marital Status Domain
SELECT DISTINCT cst_marital_status
FROM bronze.crm_cust_info;

-- Validate Create Date
SELECT *
FROM bronze.crm_cust_info
WHERE TRY_CONVERT(DATE, cst_create_date) IS NULL
   OR cst_create_date > GETDATE();


/* ===============================================================
   2️⃣ crm_prd_info
   =============================================================== */

-- Check for Null or Duplicate Product ID
SELECT prd_id, COUNT(*)
FROM bronze.crm_prd_info
GROUP BY prd_id
HAVING COUNT(*) > 1 OR prd_id IS NULL;

-- Check Negative or Null Cost
SELECT *
FROM bronze.crm_prd_info
WHERE prd_cost IS NULL OR prd_cost < 0;

-- Check Product Line Domain
SELECT DISTINCT prd_line
FROM bronze.crm_prd_info;

-- Validate Date Logic
SELECT *
FROM bronze.crm_prd_info
WHERE prd_end_dt < prd_start_dt;


/* ===============================================================
   3️⃣ crm_sales_details
   =============================================================== */

-- Check Duplicate Order Numbers
SELECT sls_ord_num, COUNT(*)
FROM bronze.crm_sales_details
GROUP BY sls_ord_num
HAVING COUNT(*) > 1;

-- Validate Order Date Format
SELECT *
FROM bronze.crm_sales_details
WHERE TRY_CONVERT(DATE, CAST(sls_order_dt AS VARCHAR(8)),112) IS NULL;

-- Validate Ship Date Format
SELECT *
FROM bronze.crm_sales_details
WHERE TRY_CONVERT(DATE, CAST(sls_ship_dt AS VARCHAR(8)),112) IS NULL;

-- Validate Due Date Format
SELECT *
FROM bronze.crm_sales_details
WHERE TRY_CONVERT(DATE, CAST(sls_due_dt AS VARCHAR(8)),112) IS NULL;

-- Validate Date Sequence
SELECT *
FROM bronze.crm_sales_details
WHERE sls_order_dt > sls_ship_dt
   OR sls_ship_dt > sls_due_dt;

-- Check Negative or Null Measures
SELECT *
FROM bronze.crm_sales_details
WHERE sls_sales IS NULL OR sls_sales < 0
   OR sls_quantity IS NULL OR sls_quantity < 0
   OR sls_price IS NULL OR sls_price < 0;

-- Validate Business Rule (Sales = Quantity × Price)
SELECT *
FROM bronze.crm_sales_details
WHERE sls_sales != sls_quantity * sls_price;


/* ===============================================================
   4️⃣ erp_cust_az12
   =============================================================== */

-- Check Duplicate or Null CID
SELECT cid, COUNT(*)
FROM bronze.erp_cust_az12
GROUP BY cid
HAVING COUNT(*) > 1 OR cid IS NULL;

-- Validate Birthdate
SELECT *
FROM bronze.erp_cust_az12
WHERE bdate > GETDATE()
   OR TRY_CONVERT(DATE, bdate) IS NULL;

-- Check Gender Domain
SELECT DISTINCT gen
FROM bronze.erp_cust_az12;


/* ===============================================================
   5️⃣ erp_loc_a101
   =============================================================== */

-- Check Duplicate or Null CID
SELECT cid, COUNT(*)
FROM bronze.erp_loc_a101
GROUP BY cid
HAVING COUNT(*) > 1 OR cid IS NULL;

-- Check Country Values
SELECT DISTINCT cntry
FROM bronze.erp_loc_a101;


/* ===============================================================
   6️⃣ erp_px_cat_g1v2
   =============================================================== */

-- Check Duplicate or Null ID
SELECT id, COUNT(*)
FROM bronze.erp_px_cat_g1v2
GROUP BY id
HAVING COUNT(*) > 1 OR id IS NULL;

-- Check Critical Null Columns
SELECT *
FROM bronze.erp_px_cat_g1v2
WHERE cat IS NULL
   OR subcat IS NULL;


/* =============================================================== */

PRINT '===========================================';
PRINT 'Bronze Layer Data Quality Checks Completed';
PRINT '===========================================';
